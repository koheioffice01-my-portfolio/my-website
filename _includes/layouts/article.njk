<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | 石田 幸平 ブログ</title>
    <!-- Open Graph / SEO Meta Tags -->
    <meta property="og:title" content="{{ title }} | 石田 幸平 ブログ">
    <meta property="og:description" content="株式会社TERASS 不動産エージェント 石田幸平のブログ記事です。阪神間を中心とした不動産に関する専門的な情報をお届けします。">
    <meta property="og:type" content="article">
    <meta property="og:image" content="https://example.com/assets/about_img_1.png">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&family=Noto+Sans+JP:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .article-header { padding: 150px 0 50px; background: var(--bg-light); text-align: center; }
        .article-category { color: var(--primary-color); font-weight: 600; margin-bottom: 15px; display: inline-block; }
        .article-title { font-size: 2.2rem; color: var(--bg-dark); max-width: 800px; margin: 0 auto 20px; line-height: 1.5; }
        .article-meta { color: var(--text-light); font-size: 0.9rem; }
        .article-body { max-width: 760px; margin: 0 auto; padding: 60px 20px; font-size: 1.05rem; line-height: 1.9; color: #444; }
        .article-body h2 { font-size: 1.6rem; color: var(--bg-dark); margin: 50px 0 20px; padding-bottom: 10px; border-bottom: 2px solid var(--primary-color); }
        .article-body h3 { font-size: 1.3rem; color: var(--bg-dark); margin: 30px 0 15px; }
        .article-body p { margin-bottom: 25px; }
        .article-body .highlight-box { background: var(--bg-light); border-left: 4px solid var(--primary-color); padding: 20px; margin: 30px 0; border-radius: 0 5px 5px 0; }
        .author-box { display: flex; align-items: center; background: #fff; padding: 30px; border-radius: 10px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); margin-top: 60px; gap: 20px; }
        .author-box img { width: 100px; height: 100px; border-radius: 50%; object-fit: cover; }
        .author-info h4 { margin-bottom: 5px; color: var(--bg-dark); }
        .author-info p { font-size: 0.9rem; color: var(--text-light); margin-bottom: 0; }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar scrolled" id="navbar">
        <div class="container nav-container">
            <a href="/index.html" class="logo">ISHIDA <span>KOHEI</span></a>
            <ul class="nav-links">
                <li><a href="/index.html#about">プロフィール</a></li>
                <li><a href="/index.html#services">サービス</a></li>
                <li><a href="/blog.html" class="active">ブログ</a></li>
                <li><a href="/index.html#contact" class="btn-contact-nav">お問い合わせ</a></li>
            </ul>
        </div>
    </nav>

    <!-- Article Header -->
    <header class="article-header">
        <div class="container">
            <span class="article-category"><i class="{{ categoryIcon | default('fas fa-home') }}"></i> {{ category }}</span>
            <h1 class="article-title">{{ title }}</h1>
            <div class="article-meta">
                <span><i class="far fa-clock"></i> {{ date.toLocaleDateString('ja-JP') }}</span>
                <span style="margin-left: 15px;"><i class="fas fa-pen"></i> 石田 幸平</span>
            </div>
        </div>
    </header>

    <!-- Article Body -->
    <main class="article-body">
        {{ content | safe }}

        <!-- LINE CTA -->
        <div class="line-cta" style="background: #eafbee; border: 2px solid #00B900; border-radius: 10px; padding: 40px 30px; text-align: center; margin: 60px 0;">
            <h3 style="color: #00B900; font-size: 1.5rem; margin-bottom: 15px;"><i class="fab fa-line"></i> 公式LINEで無料相談・限定情報を配信中！</h3>
            <p style="margin-bottom: 25px; color: #333; font-size: 1.05rem; line-height: 1.6;">「家を買いたい・売りたいけれど何から始めればいいかわからない…」という方は、ぜひお気軽にLINEからご相談ください。LINE登録者限定の未公開物件情報も配信しております。</p>
            <a href="https://lin.ee/97V6lAq" target="_blank" style="display: inline-block; background: #00B900; color: #fff; padding: 15px 40px; font-weight: 600; border-radius: 30px; font-size: 1.1rem; box-shadow: 0 5px 15px rgba(0, 185, 0, 0.3); transition: transform 0.3s;"><i class="fas fa-user-plus"></i> 友だち追加して相談する</a>
        </div>

        <!-- Author Info -->
        <div class="author-box">
            <img src="/assets/about_img_1.png" alt="石田 幸平">
            <div class="author-info">
                <h4>石田 幸平（ISHIDA KOHEI）</h4>
                <p>株式会社TERASS 不動産エージェント / 宅地建物取引士 / 相続診断士 / 賃貸経営管理士<br>大手不動産会社で23年間培った確かな経験と実績を活かし、阪神間を中心に洗練された住まい探しをサポート。</p>
            </div>
        </div>

        <!-- Article Navigation (Internal Linking) -->
        {% set previousPost = collections.blog | getPreviousCollectionItem(page) %}
        {% set nextPost = collections.blog | getNextCollectionItem(page) %}
        {% if previousPost or nextPost %}
        <div class="article-navigation" style="display: flex; justify-content: space-between; margin-top: 50px; padding-top: 30px; border-top: 1px solid #eee;">
            <div class="nav-prev" style="flex: 1; text-align: left; padding-right: 15px;">
                {% if previousPost %}
                <span style="font-size: 0.85rem; color: var(--text-light);"><i class="fas fa-chevron-left"></i> 前の記事</span><br>
                <a href="{{ previousPost.url }}" style="font-weight: 500; color: var(--primary-color);">{{ previousPost.data.title }}</a>
                {% endif %}
            </div>
            <div class="nav-next" style="flex: 1; text-align: right; padding-left: 15px;">
                {% if nextPost %}
                <span style="font-size: 0.85rem; color: var(--text-light);">次の記事 <i class="fas fa-chevron-right"></i></span><br>
                <a href="{{ nextPost.url }}" style="font-weight: 500; color: var(--primary-color);">{{ nextPost.data.title }}</a>
                {% endif %}
            </div>
        </div>
        {% endif %}
    </main>

    <!-- Footer -->
    <footer>
        <div class="footer-bottom">
            <p>&copy; 2026 Kohei Ishida Real Estate Portfolio. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>
